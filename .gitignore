# Python/cache artifacts
__pycache__/
*.py[cod]

# Local logs and command output
*.log
*.out
*.tmp
logs/
log/
output/
outputs/

# Generated experiment outputs
/RESULTS/
/results/
src/log/
!src/results/
src/results/*
!src/results/.gitkeep
src/scripts/
src/DSL/

# QCP generated proof artifacts
QCP/goal/*
!QCP/goal/.gitkeep

# Local scratch inputs/backups
*.backup_*/
src/input/**/*.backup_*/
src/input/**/rerun*/

# One-off local runner scripts
src/run_*.sh
src/rerun_*.sh
src/cleanup_*.py
