class FindKth {

    public static int findKth(int[] arr1, int[] arr2, int m, int n, int k) {
        int i = 0;
        int j = 0;

        for (int count = 0; count < k; count++) {
            if (i < m && (j >= n || arr1[i] <= arr2[j])) {
                if (count == k - 1) {
                    return arr1[i];
