  ensures n == c ==> \result == 1;
  ensures n > c ==> \result == 1;
  ensures c - n >= 5 ==> \result == 0;
  ensures 0 <= \result <= 9;
*/
int foo333(int n, int c) {
  int result = 1;

  if (n == c) {
    return 1;
