#include <stdlib.h>

/*@ logic integer fibo(integer n) =
      n <= 0 ? 0 : (n == 1 ? 1 : fibo(n - 1) + fibo(n - 2)); */
/*@
  requires 1 <= n;
  requires n <= 2147483646;
  assigns \result \from n;
  ensures \result >= 1;
  ensures (n == 1 || n == 2) ==> \result == 1;
*/
int foo105(int n) {

		if (n < 0) return -1;
		else if (n == 0) return 0;

		int *fib = (int *)malloc(sizeof(int) * (n + 1));
		int fib_len = n + 1;
		fib[0] = 0;
		fib[1] = 1;
		int index = 2;

		/*@
		  loop invariant 2 <= index <= fib_len;
		  loop invariant fib_len == n + 1;
		  loop invariant n >= 1;
		  loop invariant fib[0] == 0;
		  loop invariant fib[1] == 1;
		  loop invariant \forall integer i; 0 <= i < index ==> fib[i] >= 0;
		  loop assigns index, fib[0 .. fib_len - 1];
		  loop variant fib_len - index;
		*/
		while (index < fib_len) {
			fib[index] = fib[index - 2] + fib[index - 1];
			index++;
		}

		return fib[n];
}

