#include <stdlib.h>

/*@ logic integer fibo(integer n) =
      n <= 0 ? 0 : (n == 1 ? 1 : fibo(n - 1) + fibo(n - 2)); */
/*@
  requires 1 <= n;
  requires n <= 2147483646;
  assigns \nothing;
  ensures \result == fibo(n) [POSTCONDITION FAILED];
  ensures n == 1 ==> \result == 1 [POSTCONDITION FAILED];
  ensures n == 2 ==> \result == 1 [POSTCONDITION FAILED];
  ensures n > 2 ==> \result == fibo(n - 1) + fibo(n - 2) [POSTCONDITION FAILED];
  ensures \result > 0 [POSTCONDITION FAILED];
  ensures \result == 1 <==> (n == 1 || n == 2) [POSTCONDITION FAILED];
*/
int foo105(int n) {

		if (n < 0) return -1;
		else if (n == 0) return 0;

		int *fib = (int *)malloc(sizeof(int) * (n + 1));
		int fib_len = n + 1;
		fib[0] = 0;
		fib[1] = 1;
		int index = 2;

		/*@ 
		  loop invariant 2 <= index <= fib_len;
		  loop invariant fib_len == n + 1;
		  loop invariant n >= 1;
		  loop assigns index, fib[0 .. fib_len - 1];
		*/
		while (index < fib_len) {
			fib[index] = fib[index - 2] + fib[index - 1];
			index++;
		}

		return fib[n];
}

