/*@
logic boolean divides(integer n, integer d) = (d != 0) && (n % d == 0);
*/

/*@
logic integer divisor_count(integer n, integer k) =
  k <= 0 ? 0 : divisor_count(n, k - 1) + (divides(n, k) ? 1 : 0);
*/

/*@
  requires number >= 0;
  assigns \nothing;
  ensures \result != \null;
  ensures (divisor_count(number, number) % 2 == 0) ==> \result == "Even" [POSTCONDITION FAILED];
  ensures (divisor_count(number, number) % 2 != 0) ==> \result == "Odd" [POSTCONDITION FAILED];
  ensures \result == "Even" <==> (divisor_count(number, number) % 2 == 0) [POSTCONDITION FAILED];
  ensures \result == "Odd"  <==> (divisor_count(number, number) % 2 != 0) [POSTCONDITION FAILED];
*/
const char *foo280(int number)
{
    int result = 0;

    /*@
      loop invariant 1 <= c <= number + 1;
      loop invariant result == divisor_count(number, c - 1);
      loop assigns c, result;
      loop variant number - c + 1;
    */
    for (int c = 1; c <= number; c++) {
        if (number % c == 0) {
            result++;
        }
    }

    /*@ assert result == divisor_count(number, number); */

    if (result % 2 == 0) {
        return "Even";
    } else {
        return "Odd";
    }
}

