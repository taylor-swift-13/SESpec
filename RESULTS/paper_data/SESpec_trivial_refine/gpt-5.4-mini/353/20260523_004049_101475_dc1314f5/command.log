int foo353(int num) {
  if (num <= 0) {
    return num;
  }

  int result = 0;
  int max = 0;
  int sum = num;

  /*@
    loop invariant result >= 0;
    loop invariant sum >= 0;
    loop invariant max == odd_bits(result);
    loop invariant bit_length(sum) + result == bit_length(num);
    loop assigns result, max, sum;
    loop variant sum;
  */
  while (sum > 0) {
    if (result % 2 == 0) {
      max += (1 << result);
    }
    result++;
    sum /= 2;
  }

  return (num | max);
}

