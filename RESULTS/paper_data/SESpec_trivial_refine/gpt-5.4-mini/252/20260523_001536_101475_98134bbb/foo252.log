  assigns \nothing;
  ensures 0 <= \result <= n * (n - 1) / 2;
  ensures n <= 1 ==> \result == 0;
*/
int foo252(int *arr, int arr_len, int n, int sum) {
  int count = 0;

  /*@
    loop invariant 0 <= i <= n;
    loop invariant 0 <= count <= i * (2 * n - i - 1) / 2;
    loop assigns i, count;
    loop variant n - i;
  */
  for (int i = 0; i < n; i++) {

