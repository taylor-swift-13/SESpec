    /*@
      loop invariant 0 <= i <= len;
      loop invariant num >= 0;
      loop invariant \forall integer k; 0 <= k < i ==> (num & (1 << (str[k] - 'a'))) != 0;
      loop invariant \forall integer j, k; 0 <= j < k < i ==> str[j] != str[k];
      loop assigns i, num;
      loop variant len - i;
