/*@
  requires 0 <= m;
  requires m <= 2147483647;
  requires n == 0 || m == 0;
  decreases m;
  assigns \nothing;
  ensures \result == 0;
*/
int foo7(int n, int m) {

    if (m < 0) {
      return foo7(n, -m);
