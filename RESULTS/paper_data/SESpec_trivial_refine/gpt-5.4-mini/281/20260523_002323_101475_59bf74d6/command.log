    ensures \result[1] == 'd';
    ensures \result[2] == 'd';
    ensures \result[3] == '\0';

  complete behaviors;
  disjoint behaviors;
*/
const char * foo281(int num) {
    int result = 0;
    int index = 1;

    /*@
      loop invariant 1 <= index <= num + 1;
      loop invariant result == divisor_count_upto(num, index - 1);
      loop invariant result >= 0;
      loop invariant num >= 0;
      loop assigns result, index;
      loop variant num - index + 1;
    */
    while (index <= num) {
        if (num % index == 0) {
            result++;
        }
        index++;
    }

    if (result % 2 == 0) {
        return "Even";
    } else {
        return "Odd";
    }
}

