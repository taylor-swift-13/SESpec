  requires num >= 0;
  assigns \nothing;

  behavior even:
    assumes num < 1 || divisor_count_upto(num, num) % 2 == 0;
    ensures \result[0] == 'E';
    ensures \result[1] == 'v';
    ensures \result[2] == 'e';
