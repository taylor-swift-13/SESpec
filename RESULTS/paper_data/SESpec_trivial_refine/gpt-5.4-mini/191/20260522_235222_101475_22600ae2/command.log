      axiom Wseq_1: Wseq(1) == 0;
      axiom Wseq_n:
        \forall integer n; n >= 2 ==> Wseq(n) == Wseq(n - 2) + 2 * Cseq(n - 1);

      axiom Cseq_0: Cseq(0) == 0;
      axiom Cseq_1: Cseq(1) == 1;
      axiom Cseq_n:
        \forall integer n; n >= 2 ==> Cseq(n) == Wseq(n - 1) + Cseq(n - 2);

      axiom Wseq_nonneg:
        \forall integer n; n >= 0 ==> Wseq(n) >= 0;

      axiom Wseq_odd_zero:
        \forall integer n; n >= 0 && n % 2 == 1 ==> Wseq(n) == 0;

      axiom Wseq_even_pos:
