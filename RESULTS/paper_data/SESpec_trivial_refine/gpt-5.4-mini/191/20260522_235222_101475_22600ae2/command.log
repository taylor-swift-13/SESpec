#include <stdlib.h>
#include <limits.h>

/*@ axiomatic Seqs {
      logic integer Wseq(integer n);
      logic integer Cseq(integer n);

      axiom Wseq_0: Wseq(0) == 1;
      axiom Wseq_1: Wseq(1) == 0;
      axiom Wseq_n:
        \forall integer n; n >= 2 ==> Wseq(n) == Wseq(n - 2) + 2 * Cseq(n - 1);

      axiom Cseq_0: Cseq(0) == 0;
      axiom Cseq_1: Cseq(1) == 1;
      axiom Cseq_n:
        \forall integer n; n >= 2 ==> Cseq(n) == Wseq(n - 1) + Cseq(n - 2);

      axiom Wseq_nonneg:
        \forall integer n; n >= 0 ==> Wseq(n) >= 0;

      axiom Wseq_odd_zero:
        \forall integer n; n >= 0 && n % 2 == 1 ==> Wseq(n) == 0;

      axiom Wseq_even_pos:
        \forall integer n; n >= 0 && n % 2 == 0 ==> Wseq(n) > 0;
    }
*/

/*@
    requires 1 <= count && count < INT_MAX;
    assigns \nothing;
    ensures \result == Wseq(count);
    ensures count % 2 == 1 ==> \result == 0;
    ensures count % 2 == 0 ==> \result > 0;
    ensures \result >= 0 [POSTCONDITION FAILED];
*/
