      loop invariant 2 <= i;
      loop invariant \forall integer k; 2 <= k < i ==> a % k != 0;
      loop assigns i;
    */
    while (i <= mid) {
        if (a % i == 0)
            return 0;
        i++;
    }

    return 1;
}

