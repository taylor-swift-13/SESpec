#include <stdlib.h>

/*@ logic integer foo269_div(integer n, integer w) =
      n == 0 ? 1 :
      n == 1 ? w :
      n == 2 ? w * w :
      ((w - 1) * (foo269_div(n - 1, w) + foo269_div(n - 2, w))) % 1000000007; */

/*@
  requires dim >= 2;
  requires 0 <= w <= 1000000006;
  assigns \result \from dim, w;
  ensures \result == foo269_div(dim, w);
*/
int foo269(int dim, int w) {
    const int count = 1000000007;
    int *div = (int *)malloc((size_t)(dim + 1) * sizeof(int));

    div[0] = 1;
    div[1] = w;
    div[2] = (int)(((long long)w * (long long)w) % count);

    /*@
      loop invariant 3 <= d <= dim + 1;
      loop invariant div[0] == foo269_div(0, w);
      loop invariant div[1] == foo269_div(1, w);
      loop invariant div[2] == foo269_div(2, w);
      loop invariant \forall integer k; 3 <= k < d ==> div[k] == foo269_div(k, w);
      loop invariant \forall integer k; 0 <= k < d ==> 0 <= div[k] <= 1000000006;
      loop assigns d, div[0..dim];
      loop variant dim - d + 1;
    */
    for (int d = 3; d <= dim; d++) {
        long long tmp =
            (long long)(w - 1) * ((long long)div[d - 1] + (long long)div[d - 2]);
        div[d] = (int)(tmp % count);
    }

    return div[dim];
}

