int foo250(int * args, int args_len, int start, int stop) {

  int result = start;
  int total = stop;
  int mid;
  int i;

  /*@
    loop invariant start <= result <= stop + 1;
    loop invariant start - 1 <= total <= stop;
    loop invariant result <= total + 1;
