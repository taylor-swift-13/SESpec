  for (c = 0; c < number; c++) {
    b[c] = result[c];
    if (result[c] % 2 != 0) {
      j++;
      if (j == p) {
        return c + 1;
      }
    }
  }

  /*@
    loop invariant 0 <= c <= number;
    loop invariant 0 <= j <= number + c;
    loop assigns c, j, b[0 .. number-1];
    loop variant number - c;
  */
  for (c = 0; c < number; c++) {
    b[c] = result[c];
    if (result[c] % 2 == 0) {
      j++;
      if (j == p) {
