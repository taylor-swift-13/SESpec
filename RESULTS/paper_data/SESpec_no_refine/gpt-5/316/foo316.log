    (t < 2) ? 0 :
    (t == 2 ? ((2 <= t && 2 <= n / 2 && n % 2 == 0) ? 1 : 0)
            : count_divisors_up_to(n, t - 1) + ((t <= n / t && n % t == 0) ? 1 : 0));
*/

/*@
  ensures \result >= 0;
  ensures number == 1 ==> \result == 1;
  assigns \nothing;
*/
int foo316(int number) {

    int result = 0;
    if (number == 1)
        return 1;

    /*@
      loop invariant result >= 0;
      loop assigns c, result;
