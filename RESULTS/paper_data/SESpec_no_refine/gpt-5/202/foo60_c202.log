int foo60_c202(int * ints, int ints_len, int array) {

		int find = 0;
		int min = 0;
		int offset = 1;

		/*@
          loop invariant (min == 0 && offset == 1 && find == 0) ||
                          (min + offset + find >= 1);
          loop invariant (0 < \at(array,Pre) && 1 < \at(array,Pre)) ==> (0 <= find <= (min + offset - 1));
