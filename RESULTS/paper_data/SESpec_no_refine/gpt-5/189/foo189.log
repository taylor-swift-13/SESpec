/*@
  assigns \nothing;
  ensures n == 0 ==> \result == 0;
*/
int foo189(int n, int * arr, int arr_len) {

        if (n == 0) {
            return 0;
        }

        int min = arr[0];
        int count = 1;

        /*@
          loop invariant \forall integer k; 0 <= k < arr_len ==> arr[k] == \at(arr[k], Pre);
          loop invariant arr_len == \at(arr_len,Pre);
