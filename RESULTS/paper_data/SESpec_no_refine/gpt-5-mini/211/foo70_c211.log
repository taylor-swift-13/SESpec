int foo70_c211(int * arr, int arr_len, int n) {

        int count = 0;
        int i = 0;
        int j = 1;

        
            
        /*@
          loop invariant (0 < \at(n,Pre) && 1 < \at(n,Pre)) ==> (1 <= j && j <= n);
          loop invariant (!(0 < \at(n,Pre) && 1 < \at(n,Pre))) ==> ((j == 1)&&(i == 0)&&(count == 0)&&(n == \at(n,Pre))&&(arr_len == \at(arr_len,Pre))&&(arr == \at(arr,Pre)));
