/*@
  requires \valid(arr + (0..arr_len-1)) || arr_len == 0;
  requires arr_len >= 0;
  assigns \nothing;
*/
int foo42(int * arr, int arr_len) {

        int n = arr_len;
        if (n < 2) {
            return 1;
        }
        
        /*@
          loop invariant 0 <= i <= n;
          loop invariant \forall integer k; 0 <= k < n ==> arr[k] == \at(arr[k], Pre);
