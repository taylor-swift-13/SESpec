/*@
  assigns \nothing;
*/
int foo252(int size) {

		int average = 0;
		int total = 0;
		
            
        /*@
          loop invariant size == \at(size,Pre);
          loop assigns c, average, total;
            */
            for (int c = 1; c <= size; c++) {
			if (c % 2 != 0) {
				average += c;
				total++;
			}
		}
            
		return average / total;
}

