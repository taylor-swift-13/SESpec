/*@ 
  ensures \result == 1 || \result > n;
  
  ensures n < 1 ==> \result == 1;
  ensures n >= 1 ==> \result > n;
  assigns \nothing;
*/
int foo391(int n) {

        int i = 1;
        int square = 1;
        
            
        /*@
          loop invariant (1 <= \at(n,Pre)) ==> (1 <= i);
          loop invariant (!(1 <= \at(n,Pre))) ==> ((square == 1)&&(i == 1)&&(n == \at(n,Pre)));
          loop invariant n == \at(n,Pre);
          loop assigns square, i;
            */
            while (square <= n) {
            square = i*i;
            i++;
        }
            
        return square;
}

