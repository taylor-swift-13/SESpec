/*@ 
  assigns \nothing;
  
*/
int foo367(int n) {

    int i = 2;

    /*@
      loop invariant 2 <= i;
      loop invariant n == \at(n,Pre);
      loop assigns i;
    */
    while (i <= n / i) {
        if (n % i == 0) {
            return i;
        }
        i++;
    }

    return n;
}

