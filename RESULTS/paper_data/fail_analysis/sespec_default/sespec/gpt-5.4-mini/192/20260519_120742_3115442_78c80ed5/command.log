int foo192(int count) {

		int *w = (int *)malloc(sizeof(int) * (count + 1));
		int w_len = count + 1;
		int *C = (int *)malloc(sizeof(int) * (count + 1));
		int C_len = count + 1;
		w[0] = 1;
		w[1] = 0;
		C[0] = 0;
