/*@
  assigns \nothing;
*/
int foo147(int n) {

    int temp = n;

    /*@
      loop invariant (!(\at(n,Pre) != 0 && \at(n,Pre) % 3 == 0)) ==> ((temp == \at(n,Pre)) && (n == \at(n,Pre)));
      loop invariant n == \at(n,Pre);
