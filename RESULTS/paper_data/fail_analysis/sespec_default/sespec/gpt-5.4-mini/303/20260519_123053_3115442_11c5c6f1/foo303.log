/*@
  requires n >= 1;
  assigns \nothing;
*/
int foo303(int n) {

    int *dp = (int *)malloc(sizeof(int) * (n + 1));
    int dp_len = n + 1;
    dp[0] = 2;
    dp[1] = 1;

    /*@
      loop invariant 2 <= i <= n + 1;
      loop invariant dp[0] == 2;
      loop invariant dp[1] == 1;
      
      loop assigns i, dp[0..n];
    */
    for (int i = 2; i <= n; i++) {
        dp[i] = dp[i - 1] + 2 * dp[i - 2];
    }

    return dp[n];
}

