/*@
  requires \valid_read(s + (0 .. strlen(s)));
  requires \valid_read(t + (0 .. strlen(t)));
  assigns \nothing;
  ensures \result == 1 <==> \result != 0;
*/
int foo124(const char * s, const char * t) {

        int n = ((int)strlen(s)), m = ((int)strlen(t));
        int i = 0, j = 0;

        /*@
          loop invariant i <= n;
          loop invariant j <= m;
          loop assigns i, j;
        */
        while (i < n && j < m) {
            if (s[i] == t[j]) {
                i++;
            }
            j++;
        }

        return i == n;
}

