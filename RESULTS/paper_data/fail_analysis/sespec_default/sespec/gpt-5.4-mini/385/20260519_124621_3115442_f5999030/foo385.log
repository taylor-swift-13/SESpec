int foo385(int n, int m) {

    /*@
      loop invariant m == \at(m,Pre);
      loop invariant n == \at(n,Pre);
      loop invariant i <= n;
      loop invariant (i >= 0) ==> (m == \at(m,Pre) && n == \at(n,Pre));
