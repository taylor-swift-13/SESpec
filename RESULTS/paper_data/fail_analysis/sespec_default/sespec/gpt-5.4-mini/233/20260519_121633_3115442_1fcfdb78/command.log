int foo233(int * arr, int arr_len) {

		int result = arr[0];
		int num = arr[0];
		
        /*@
          loop invariant result >= arr[0];
          loop invariant num <= arr[0];
          loop invariant \forall integer i; 0 <= i < n ==> arr[i] <= result;
          loop invariant \forall integer i; 0 <= i < n ==> num <= arr[i];
