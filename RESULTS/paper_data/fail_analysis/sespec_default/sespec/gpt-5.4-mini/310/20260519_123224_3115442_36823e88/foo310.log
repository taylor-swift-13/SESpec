*/
int foo310(int num) {
    if (num < 0) {
        return -1;
    }
    int left = 0;
    int right = num;

    /*@
      loop invariant num == \at(num,Pre);
      loop invariant 0 <= left;
      loop invariant right <= num;
      loop invariant left <= right + 1;
      loop assigns left, right;
      loop variant right - left + 1;
