  logic integer recN(int* N, integer i) =
      i <= 0 ? 2 :
      i == 1 ? 1 :
      recN(N, i - 1) + 2 * recN(N, i - 2);
*/

int foo290(int c) {

		int *N = (int *)malloc(sizeof(int) * (c + 1));
int N_len = c + 1;
		N[0] = 2;
		N[1] = 1;
		
            
        /*@
