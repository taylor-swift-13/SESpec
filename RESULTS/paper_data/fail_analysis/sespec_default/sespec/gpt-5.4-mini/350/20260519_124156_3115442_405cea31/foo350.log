/*@
  ensures (\at(num,Pre) <= 0) ==> (\result == \at(num,Pre));
  assigns \nothing;
*/
int foo350(int num) {

		int result = 0;
		int ret = 0;
		int total = num;
		
        /*@
          loop invariant (\at(num,Pre) > 0) ==> (0 <= ret);
          loop invariant (\at(num,Pre) > 0) ==> (0 <= total);
          loop invariant (!(\at(num,Pre) > 0)) ==> ((total == \at(num,Pre))&&(ret == 0)&&(result == 0)&&(num == \at(num,Pre)));
          loop invariant num == \at(num,Pre);
          loop assigns result, total, ret;
        */
        while (total > 0) {
			if (ret % 2 == 0) {
				result = result | (1 << ret);
			}
			ret++;
			total >>= 1;
		}
            
		return num ^ result;
}

