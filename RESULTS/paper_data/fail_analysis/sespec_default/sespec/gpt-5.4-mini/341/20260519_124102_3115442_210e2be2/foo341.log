/*@
  assigns \nothing;
  
  ensures \result >= 0;
*/
int foo341(int num, int z) {

		if (z < 0) {
			z = -z;
		}
		int result = 0;
		
            
        /*@
          loop invariant 1 <= loop <= z + 1;
          loop invariant 0 <= result <= loop - 1;
