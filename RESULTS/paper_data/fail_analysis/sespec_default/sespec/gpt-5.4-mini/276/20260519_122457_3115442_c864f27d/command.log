#include <stdlib.h>

/*@
  logic integer pow2(integer x) = x * x;
*/

/*@
  requires n >= 2;
  assigns \nothing;
  
*/

int foo276(int n, int k) {

        int mod = 1000000007;
        int *dp = (int *)malloc(sizeof(int) * (n+1));
        int dp_len = n+1;
        dp[0] = 1;
        dp[1] = k;
        dp[2] = k*k;
        
            
        /* >>> LOOP INVARIANT TO FILL <<< */
        
            /*@
