          loop invariant dp[0] == 1;
          loop invariant dp[1] == k;
          loop invariant dp[2] == k*k;
          loop assigns i, dp[3..n];
            */
            for(int i=3;i<=n;i++){
            dp[i] = ((k-1) * (dp[i-1] + dp[i-2])) % mod;
        }
            
        return dp[n];
}

