int foo185(int * a, int a_len, int x) {

        int low = 0, high = a_len - 1;
        
            
        /* >>> LOOP INVARIANT TO FILL <<< */
        
            /*@
          loop invariant x == \at(x,Pre);
          loop invariant a_len == \at(a_len,Pre);
