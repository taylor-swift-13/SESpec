/*@ 
  logic integer power(integer base, integer exp) = 
    (exp == 0) ? 1 : base * power(base, exp - 1);
*/

/*@
  requires \true;
  assigns \nothing;
  ensures n <= 0 ==> \result == 1;
  ensures n > 0 ==> \result == power(x, n);
*/
int foo135(int x, int n) {

        int res = 1;
        /*@
          loop invariant 0 <= i <= n;
          loop invariant res == power(x, i);
          loop assigns i, res;
          loop variant n - i;
        */
        for(int i = 0; i < n; i++)
            res = res * x;
        return res;
}

