int foo101(int * nums, int nums_len) {

    int max = nums[0];
    int min = nums[0];
    
    /*@
      loop invariant 1 <= i <= nums_len;
      loop invariant max == max_in_range(nums, 0, i);
      loop invariant min == min_in_range(nums, 0, i);
