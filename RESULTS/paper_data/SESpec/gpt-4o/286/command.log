#include <stdlib.h>

/*@
  logic integer fib_like(int j) =
    j == 0 ? 0 :
    j == 1 ? 1 :
    fib_like((int)(j - 1)) + 2 * fib_like((int)(j - 2));
*/

/*@
  requires j >= 0;
  assigns \nothing;
  ensures \result == fib_like(j);
  ensures \result == 0 ==> j == 0 || j == 1;
*/
int foo286(int j) {
    int *r = (int *)malloc(sizeof(int) * (j + 1));
    int r_len = j + 1;
    r[0] = 0;
    r[1] = 1;

    /*@
      loop invariant 2 <= p <= j + 1;
      loop invariant \forall int k; 0 <= k < p ==> r[k] == fib_like(k);
      loop assigns r[0..j];
    */
    for (int p = 2; p <= j; p++) {
        r[p] = r[p - 1] + 2 * r[p - 2];
    }

    return r[j];
}

