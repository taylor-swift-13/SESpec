#include <stdlib.h>

/*@
  logic integer fib_like(int j) =
    j == 0 ? 0 :
    j == 1 ? 1 :
    fib_like((int)(j - 1)) + 2 * fib_like((int)(j - 2));
*/

/*@
  requires j >= 0;
  assigns \nothing;
  ensures \result == fib_like(j);
  ensures \result == 0 ==> j == 0 || j == 1;
*/
int foo286(int j) {
