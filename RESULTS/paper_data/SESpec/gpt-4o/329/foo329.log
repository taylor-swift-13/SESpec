    int ret = 0;
    int max = 0;

    /*@
      loop invariant diff == \at(diff, Pre);
      loop invariant 1 <= j <= diff + 1;
      loop assigns j, ret;
      loop variant diff - j; // Decreasing loop variant
    */
    for (int j = 1; j <= diff; j++) {
        ret += j * j * j;
