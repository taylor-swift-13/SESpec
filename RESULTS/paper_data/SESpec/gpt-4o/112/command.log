  assigns \nothing;
*/
int foo112(const char * str) {
    /*@ assert \valid_read(str + (0 .. strlen(str) - 1)); */
    int len = ((int)strlen(str));
    if (len > 26) {
        return 0;
    }
    int num = 0;

    /*@
      loop invariant 0 <= i <= len;
      loop invariant \valid_read(str + (0 .. len - 1));
      loop invariant \forall integer k; 0 <= k < i ==> ((num & (1 << (str[k] - 'a'))) != 0);
      loop invariant \forall integer k; 0 <= k < i ==> \forall integer l; k < l < i ==> str[k] != str[l];
      loop assigns i, num;
      loop variant len - i;
