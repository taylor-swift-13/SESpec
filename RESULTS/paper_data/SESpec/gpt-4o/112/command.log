                           (str[i] >= 'a' && str[i] <= 'z' && str[j] >= 'a' && str[j] <= 'z' && str[i] != str[j]);
  ensures \result == 0 ==> \exists integer i, j [POSTCONDITION FAILED]; 0 <= i < j < strlen(str) && 
                           (str[i] >= 'a' && str[i] <= 'z' && str[j] >= 'a' && str[j] <= 'z' && str[i] == str[j]);
*/
int foo112(const char * str) {
    /*@ assert \valid_read(str + (0 .. strlen(str) - 1)); */
    int len = ((int)strlen(str));
    if (len > 26) {
        return 0;
    }
    int num = 0;

    /*@
      loop invariant 0 <= i <= len;
      loop invariant \forall integer k; 0 <= k < i ==> str[k] == \at(str[k], Pre);
      loop invariant \forall integer k; 0 <= k < i ==> (str[k] >= 'a' && str[k] <= 'z');
      loop invariant \forall integer k; 0 <= k < i ==> (num & (1 << (str[k] - 'a'))) != 0;
      loop assigns i, num;
      loop variant len - i;
    */
    for (int i = 0; i < len; i++) {
        char c = str[i];
        int index = c - 'a';
        if (c < 'a' || c > 'z') {
            continue; // Ignore non-lowercase alphabetic characters
        }
        if ((num & (1 << index)) != 0) {
            return 0;
        } else {
            num |= (1 << index);
        }
    }

    return 1;
}

