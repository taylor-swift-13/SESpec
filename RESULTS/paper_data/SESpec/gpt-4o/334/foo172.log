/*@
  logic integer sum_of_cubes(integer n) =
    n <= 0 ? 0 : n * n * n + sum_of_cubes(n - 1);

  logic integer sum_of_integers(integer n) =
    n <= 0 ? 0 : n + sum_of_integers(n - 1);
