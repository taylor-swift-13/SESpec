  requires n >= 0;
  assigns \nothing;
  ensures \result == sum_of_cubes(n) - sum_of_integers(n);
*/
int foo172(int n) {
    int sum = 0;
    int sum1 = 0;

    /*@
      loop invariant 1 <= i <= n + 1;
      loop invariant sum == sum_of_cubes(i - 1);
      loop invariant sum1 == 0;
      loop invariant n == \at(n,Pre);
      loop assigns i, sum;
      loop variant n - i;
