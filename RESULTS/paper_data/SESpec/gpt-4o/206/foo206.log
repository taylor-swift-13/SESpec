  ensures \result == args_len ==> (\forall integer k; 0 <= k < args_len ==> (\exists integer j; 0 <= j < arr_len && args[k] == arr[j]) || (\forall integer j; 0 <= j < arr_len ==> args[k] != arr[j]));
  ensures \result == arr_len ==> (\forall integer k; 0 <= k < arr_len ==> (\exists integer j; 0 <= j < args_len && arr[k] == args[j]) || (\forall integer j; 0 <= j < args_len ==> arr[k] != args[j]));
  ensures \result < args_len ==> (\forall integer k; 0 <= k < \result ==> (\exists integer j; 0 <= j < arr_len && args[k] == arr[j]) || (\forall integer j; 0 <= j < arr_len ==> args[k] != arr[j]));
  ensures \result < arr_len ==> (\forall integer k; 0 <= k < \result ==> (\exists integer j; 0 <= j < args_len && arr[k] == args[j]) || (\forall integer j; 0 <= j < args_len ==> arr[k] != args[j]));
  assigns \nothing;
*/
int foo206(int * args, int args_len, int * arr, int arr_len, int array) {

    int ret = 0;
    int r = 0;
    
    /*@
      loop invariant 0 <= ret <= args_len;
      loop invariant 0 <= r <= arr_len;
      loop invariant \forall integer k; 0 <= k < ret ==> (\exists integer j; 0 <= j < r && args[k] == arr[j]) || (\forall integer j; 0 <= j < r ==> args[k] != arr[j]);
      loop invariant \forall integer k; 0 <= k < r ==> (\exists integer j; 0 <= j < ret && arr[k] == args[j]) || (\forall integer j; 0 <= j < ret ==> arr[k] != args[j]);
      loop invariant \forall integer k; 0 <= k < ret ==> args[k] == \at(args[k], Pre);
      loop invariant \forall integer k; 0 <= k < r ==> arr[k] == \at(arr[k], Pre);
      loop invariant array == \at(array,Pre);
      loop invariant arr_len == \at(arr_len,Pre);
      loop invariant arr == \at(arr,Pre);
      loop invariant args_len == \at(args_len,Pre);
      loop invariant args == \at(args,Pre);
      loop assigns ret, r;
    */
    while (ret < args_len && r < arr_len) {
        if (args[ret] < arr[r]) {
            ret++;
        } else if (args[ret] > arr[r]) {
            r++;
        } else {
            ret++;
            r++;
        }
    }
    
    return ret < args_len ? ret : r;
}

