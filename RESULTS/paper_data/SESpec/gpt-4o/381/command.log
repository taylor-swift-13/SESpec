/*@
  requires x > 0 && y > 0;
  assigns \nothing;
  ensures \result == gcd_count_upto(x, y, (x < y ? x : y));
*/
int foo290(int x, int y) {

    int count = 0;

    /*@
      loop invariant y == \at(y, Pre);
      loop invariant x == \at(x, Pre);
      loop invariant count == gcd_count_upto(x, y, i - 1);
