      loop invariant \forall integer k; 0 <= k < index ==> (args[k] % 2 != 0 ==> last_odd(args, 0, k + 1) == args[k]);
      loop invariant \forall integer k; 0 <= k < index ==> (args[k] % 2 == 0 ==> last_odd(args, 0, k + 1) == last_odd(args, 0, k));
