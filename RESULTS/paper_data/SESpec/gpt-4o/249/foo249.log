      loop assigns mid, found, num;
    */
    while (found <= num) {
        mid = (found + num) / 2;
        int i = args[mid];

        if (i == mid) {
            found = mid + 1;
        } else if (i < mid) {
            found = mid + 1;
        } else {
            num = mid - 1;
        }
    }

    return found;
}

