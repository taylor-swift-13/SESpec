    for(int i = 0; i < m; i++) {
        
        /*@
          loop invariant 0 <= j <= n;
          loop invariant res == i * n + j;
          loop assigns j, res;
        */
        for(int j = 0; j < n; j++) {
            res = res + 1;
        }
    }
    
    return sign * res;
}

