int foo240(int n) {

    int sum = 0;
    int *dp = (int *)malloc(sizeof(int) * (n + 1));
    int dp_len = n + 1;
    dp[0] = 1;

    /*@
      loop invariant 1 <= i <= n + 1;
      loop invariant \forall integer k; 0 <= k < i ==> dp[k] >= 1;
      loop assigns dp[1 .. n];
