int foo204(int n) {
    int sum = 0;

    /*@
      loop invariant 1 <= i <= n + 1;
      loop invariant n == \at(n, Pre);
      loop invariant sum == \sum(1, i - 1, \lambda integer j; (n % j == 0 && j % 2 != 0) ? j : 0);
