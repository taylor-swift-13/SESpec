  assigns \nothing;
  ensures \result == count_divisors(num, z >= 0 ? z : -z);
*/
int foo339(int num, int z) {

    if (z < 0) {
        z = -z;
    }
    int result = 0;

    /*@
      loop invariant 1 <= index <= z + 1;
      loop invariant result == count_divisors(num, index - 1);
