/*@ 
  requires \true; 
  assigns \nothing; 
  ensures (operator == '+' ==> \result == num1 + num2) &&
          (operator == '-' ==> \result == num1 - num2) &&
          (operator == '*' ==> \result == num1 * num2) &&
          (operator == '/' && num2 != 0 ==> \result == num1 / num2) &&
