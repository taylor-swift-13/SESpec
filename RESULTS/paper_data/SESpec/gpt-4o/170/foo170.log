        if (r < stop
                && arr[r] > arr[r + 1]) {
            return r + 1;
        } else if (r > ret
                && arr[r] < arr[r - 1]) {
            return r;
        }
        if (arr[r] >= arr[ret]) {
            ret = r + 1;
        } else {
            stop = r - 1;
        }
    }

    return 0;
}

