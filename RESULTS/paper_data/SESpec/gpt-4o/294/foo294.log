/*@
  logic integer fibonacci_mod(int n) =
    n == 0 ? 0 :
    n == 1 ? 1 :
    (2 * fibonacci_mod((int)(n - 1)) + fibonacci_mod((int)(n - 2))) % 1000000000;
*/

