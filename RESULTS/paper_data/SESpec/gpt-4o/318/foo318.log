      loop invariant \forall integer k; 2 <= k < c ==> (num % k == 0 ==> k <= num / k);
      loop assigns c, result;
      loop variant num / c - c;
    */
    for (int c = 2; c <= num / c; c++) {
        if (num % c == 0) {
            result++;
            if (num / c == c) {
                break;
            }
        }
    }

    return result;
}

