int foo104(int * nums, int nums_len) {

    int biggest_index = 0;

    /*@
      loop invariant 0 <= i <= nums_len;
      loop invariant 0 <= biggest_index < nums_len;
      loop invariant \forall integer k; 0 <= k < i ==> nums[biggest_index] >= nums[k];
