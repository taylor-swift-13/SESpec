/*@ 
  predicate valid_array(int *arr, integer len) = 
    \valid(arr + (0 .. len - 1)) && 
    (\forall integer i; 0 <= i < len ==> arr[i] >= 0);
*/

/*@
  requires b >= 0;
  assigns \nothing;
  ensures \result >= 0;
*/
int foo227(int b) {

    int result = 0;
    int *arr = (int *)malloc(sizeof(int) * (b + 1));
    int arr_len = b + 1;
    arr[0] = 1;

    /*@
      loop invariant 1 <= d <= b + 1;
      loop invariant arr[0] == 1;
      loop invariant valid_array(arr, d);
      loop assigns arr[1 .. b];
    */
    for (int d = 1; d <= b; d++) {

        /*@
          loop invariant 0 <= c <= d;
          loop invariant arr[0] == 1;
          loop invariant valid_array(arr, d);
          loop assigns arr[d];
        */
        for (int c = 0; c < d; c++) {
            arr[d] = arr[d] + arr[c];
        }
    }
    return arr[b];
}

