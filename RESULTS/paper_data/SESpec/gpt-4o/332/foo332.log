        return 0;
    } else {

        /*@
          loop invariant c == \at(c,Pre);
          loop invariant num == \at(num,Pre);
          loop invariant result == product_mod10(\at(num,Pre) + 1, var - 1);
          loop invariant num + 1 <= var <= c + 1;
          loop invariant result % 10 == product_mod10(\at(num,Pre) + 1, var - 1); // Strengthened invariant
