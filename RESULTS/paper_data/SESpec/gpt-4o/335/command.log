    int variable = 1;
    if (a == b) {
        return 1;
    } else if ((b - a) >= 5) {
        return 0;
    } else {
        /*@
          loop invariant b == \at(b,Pre);
          loop invariant a == \at(a,Pre);
          loop invariant a + 1 <= i <= b + 1;
          loop invariant variable == product_mod_10(a + 1, i - 1) % 10;
          loop invariant \forall integer k; a + 1 <= k < i ==> variable == product_mod_10(a + 1, k) % 10;
          loop assigns i, variable;
          loop variant b - i;
        */
        for (int i = a + 1; i < b + 1; i++) {
            /*@
