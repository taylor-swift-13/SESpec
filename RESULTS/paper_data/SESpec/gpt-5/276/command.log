int foo157_c276(int n, int k) {

        int mod = 1000000007;
        int *dp = (int *)malloc(sizeof(int) * (n+1));
        int dp_len = n+1;
        dp[0] = 1;
        dp[1] = k;
        dp[2] = k*k;
        
        /*@
          loop invariant 3 <= i;
          loop invariant dp_len == n+1;
