/*@
  logic integer pow2(integer n) =
    n <= 0 ? 1 : 2 * pow2(n - 1);
*/

/*@
  logic integer closed_j(integer p) =
    (pow2(p) - ((p % 2 == 0) ? 1 : -1)) / 3;
*/

/*@
  requires c >= 1;
  assigns \nothing;
  ensures \result == closed_j(c);
  ensures \result >= 0 [POSTCONDITION FAILED];
