  ensures (c % 2 == 0) ==> (3 * \result == pow2(c) - 1) [POSTCONDITION FAILED];
  ensures (c % 2 != 0) ==> (3 * \result == pow2(c) + 1) [POSTCONDITION FAILED];
  ensures \result >= 0 [POSTCONDITION FAILED];
*/
int foo287(int c) {

    int *j = (int *)malloc(sizeof(int) * (c + 1));
    int j_len = c + 1;
    j[0] = 0;
    j[1] = 1;

