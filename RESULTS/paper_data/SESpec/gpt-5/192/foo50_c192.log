      loop invariant w[0] == w[0] && w[1] == w[1] && C[0] == C[0] && C[1] == C[1];
      loop assigns index, w[0 .. w_len-1], C[0 .. C_len-1];
    */
    for (int index = 2; index <= count; index++) {
        w[index] = w[index - 2]
                + 2 * C[index - 1];
        C[index] = w[index - 1] + C[index - 2];
    }
            
    return w[count];
}

