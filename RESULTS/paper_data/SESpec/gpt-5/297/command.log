int foo297(int seed) {

    int *result = (int *)malloc(sizeof(int) * (seed + 1));
    int result_len = seed + 1;
    result[0] = 2;
    result[1] = 1;

    /*@
      loop invariant 2 <= l <= seed + 1;
      loop invariant result_len == seed + 1;
      loop invariant result[0] == 2;
      loop invariant result[1] == 1;
