              loop invariant j >= 2;
              loop invariant num >= 1;
              loop invariant ret == 0 || (ret >= 2 && ret <= j);
              loop assigns ret, num;
            */
            while (num % j == 0) {
				ret = j;
				num /= j;
			}
            
		}
            
		return ret;
}

