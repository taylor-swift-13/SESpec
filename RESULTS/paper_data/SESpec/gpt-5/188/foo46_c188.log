           : (n == 1 ? a[0]
                     : (min_prefix(a, n-1) <= a[n-1] ? min_prefix(a, n-1) : a[n-1]));
*/

/*@
  logic integer count_eq_prefix(int* a, integer n, integer v) =
    n <= 0 ? 0
           : count_eq_prefix(a, n-1, v) + (a[n-1] == v ? 1 : 0);
