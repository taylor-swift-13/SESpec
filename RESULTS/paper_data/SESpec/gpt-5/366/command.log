        int sum = 0;
        int count = 0;
        
        /*@
          loop invariant sum >= 0 && count >= 0;
          loop invariant count == ((i - 1) / 2);
          loop invariant sum == ((i - 1) / 2) * (((i - 1) / 2) + 1);
