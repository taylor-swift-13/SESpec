int foo368(int n, int r, int p) {

    if (n < r) {
        return 0;
    }

    int ncr = 1;

    /*@
      loop invariant 1 <= i <= r + 1;
      loop invariant r == \at(r,Pre);
      loop invariant n == \at(n,Pre);
