int foo352(int number) 
{

    int result = 0;
    int ret = 0;
    int total = number;
        
    /*@
      loop invariant 0 <= ret;
      loop invariant number == \at(number,Pre);
      loop invariant total == (\at(number,Pre) >> ret);
      loop invariant (\forall integer k; 0 <= k < ret ==> 
