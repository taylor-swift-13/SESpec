ensures (n / 400 != 0) && (n / 100 == 0) ==> (\result == (n - n / 4 - n / 400 + (n / 4 + n / 400) * 2) % 7);
ensures (n / 400 != 0) && (n / 100 != 0) ==> (\result == (n - n / 4 + n / 100 - n / 400 + (n / 4 - n / 100 + n / 400) * 2) % 7);

assigns \nothing;
