      loop invariant \forall integer k; 3 <= k < d ==> (k-1 >= 0 && k-2 >= 0 && k-1 < d && k-2 < d);
      loop invariant \forall integer k; 0 <= k < div_len ==> (k > count ==> div[k] == div[k]);
      loop assigns d, div[0..count];
    */
    for (int d = 3; d <= count; d++) {
        div[d] = ((w - 1)
                * (div[d - 1] + div[d - 2])) % result;
    }
            
    return div[count];
}

