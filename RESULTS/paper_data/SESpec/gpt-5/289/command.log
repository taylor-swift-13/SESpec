#include <stdlib.h>

/*@ logic integer j_val(integer n) =
      n <= 0 ? 2 :
      n == 1 ? 1 :
      j_val(n - 1) + 2 * j_val(n - 2); */

/*@
  requires c >= 1;
  assigns \nothing;

  ensures c == 1 ==> \result == 1;
  ensures c >= 2 ==> \result == j_val(c - 1) + 2 * j_val(c - 2) [POSTCONDITION FAILED];
  ensures \result >= 1 [POSTCONDITION FAILED];
*/
int foo289(int c) {

    int *j = (int *)malloc(sizeof(int) * (c + 1));
    int j_len = c + 1;
    j[0] = 2;
    j[1] = 1;

    /*@
      loop invariant 2 <= d <= c + 1;
      loop invariant 0 <= d <= j_len;
      loop invariant j_len == c + 1;
      loop invariant j[0] == 2;
      loop invariant j[1] == 1;
      loop invariant \forall integer k; 2 <= k < d ==> j[k] == j[k-1] + 2 * j[k-2];
      loop invariant \forall integer k; 0 <= k < d ==> k < j_len;
      loop assigns d, j[0..j_len-1];
    */
    for (int d = 2; d <= c; d++) {
        j[d] = j[d - 1]
                + 2 * j[d - 2];
    }

    return j[c];
}

