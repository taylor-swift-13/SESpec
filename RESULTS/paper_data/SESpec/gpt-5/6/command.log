    // Linear recursion on a counter. The spec couples a `decreases n`
// termination measure with a `logic integer fact` definition so the
// `ensures \result == fact(n)` postcondition is checkable.

/*@
  logic integer fact(integer n) =
    n <= 0 ? 1 : n * fact(n - 1);
*/

/*@
  requires n >= 0;
  decreases n;
  ensures \result == fact(n);
*/
int factorial(int n) {
    if (n == 0) {
        return 1;
    }
    return n * factorial(n - 1);
}


// Binary recursion. Same `decreases n` + matching `logic integer fib`
// pattern as factorial; both recursive calls reduce the measure so the
// termination obligation discharges.

/*@
  logic integer fib(integer n) =
    n <= 0 ? 0 : (n == 1 ? 1 : fib(n - 1) + fib(n - 2));
*/

/*@
  requires n >= 0;
  decreases n;
  ensures \result == fib(n);
*/
int fibonacci(int n) {
    if (n < 2) {
        return n;
    }
    return fibonacci(n - 1) + fibonacci(n - 2);
}


// Recursive sum over an array slice. `decreases hi - lo` discharges
// termination; the recursive `logic integer arrsum` mirrors the C
// recursion so `ensures \result == arrsum(a, lo, hi)` is provable.

/*@
  logic integer arrsum(int* a, integer lo, integer hi) =
    lo >= hi ? 0
             : a[lo] + arrsum(a, lo + 1, hi);
*/

/*@
  requires \valid_read(a + (lo..hi-1));
  requires lo <= hi;
  decreases hi - lo;
  ensures \result == arrsum(a, lo, hi);
*/
int recursive_sum(int* a, int lo, int hi) {
    if (lo >= hi) {
        return 0;
    }
    return a[lo] + recursive_sum(a, lo + 1, hi);
}

