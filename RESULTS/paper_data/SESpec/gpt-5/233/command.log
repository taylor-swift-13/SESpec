    int cnt = 0;
    int i = 0;

    /*@
      loop invariant 0 <= i <= n;
      loop invariant 0 <= cnt <= i;
      loop invariant cnt == cntpos(a, 0, i);
      loop assigns i, cnt;
      loop variant n - i;
    */
    while (i < n) {
        if (a[i] > 0) {
            cnt++;
        }
        i++;
    }
    return cnt;
}


