/*@ logic integer fact_nonneg(integer n) =
      n <= 0 ? 1 : n * fact_nonneg(n - 1); */
/*@
  assigns \nothing;
  ensures (num <= 0) ==> (\result == 1) [POSTCONDITION FAILED];
