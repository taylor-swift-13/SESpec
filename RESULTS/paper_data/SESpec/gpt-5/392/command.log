int foo392(int num) {

    int ret = 1;

    /*@
      loop invariant num == \at(num,Pre);
      loop invariant ret >= 1;
      loop invariant ret == prefix_prod(number - 1);
      loop invariant (number <= \at(num,Pre)) ==> (number >= 1);
      loop assigns number, ret;
