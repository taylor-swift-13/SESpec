          loop invariant \forall integer k; 0 <= k < i ==> mpis[k] <= max;
          loop assigns i, max;
        */
        for (int i = 1; i < n; i++) {
            if (mpis[i] > max) {
                max = mpis[i];
            }
        }
            
        return max;
}

