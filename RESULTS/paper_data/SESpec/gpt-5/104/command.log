          loop invariant \forall integer k; 0 <= k && k < nums_len ==> nums[k] == \at(nums[k], Pre);
          loop invariant \forall integer k; 0 <= k && k < i ==> (k != biggest_index ==> 2 * nums[k] <= nums[biggest_index]);
