int foo392(int num) {
	int ret = 1;

	/*@
	  loop invariant number >= 1;
	  loop invariant num == \at(num,Pre);
	  loop invariant ret == fact(number - 1);
	  loop invariant ret >= 1;
	  loop invariant ret == fact(number - 1) && (number - 1) >= 0;
