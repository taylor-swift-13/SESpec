          loop invariant l <= i;
          loop invariant (l <= r + 1) ==> (i <= r + 1);
          loop invariant !(l <= r + 1) ==> (i == l);
          loop invariant sum + oddsum(i, r) == oddsum(l, r);
          loop assigns i, sum;
            */
            for (int i = l; i <= r; i++) {
            if (i % 2 != 0) {
                sum += i;
            }
        }
            
        return sum;
}

