/*@
  logic integer cube_sum(integer n) =
    n <= 0 ? 0 : cube_sum(n - 1) + n * n * n;
*/

/*@ 
  logic integer tri_sum(integer n) =
    n <= 0 ? 0 : tri_sum(n - 1) + n;
