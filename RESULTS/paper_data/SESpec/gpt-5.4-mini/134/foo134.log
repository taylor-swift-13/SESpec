/*@
  assigns \nothing;
  ensures \result == x * y;
  ensures x == 0 || y == 0 ==> \result == 0;
  ensures (x >= 0 && y >= 0) ==> \result >= 0;
  ensures (x < 0 && y < 0) ==> \result >= 0;
  ensures ((x < 0) != (y < 0)) ==> \result <= 0;
  ensures (x >= 0 && y >= 0) ==> \result == x * y;
  ensures (x < 0 && y >= 0) ==> \result == x * y;
  ensures (x >= 0 && y < 0) ==> \result == x * y;
  ensures (x < 0 && y < 0) ==> \result == x * y;
*/
int foo134(int x, int y) {

        int res = 0, m = x, n = y, sign = 1;
        if(x < 0){
            m = -x;
            sign = -sign;
        }
        if(y < 0){
            n = -y;
            sign = -sign;
        }
        /*@
          loop invariant 0 <= i <= m;
          loop invariant res == i * n;
          loop invariant 0 <= n;
          loop assigns i, res;
        */
        for(int i = 0; i < m; i++) {
            /*@
              loop invariant 0 <= j <= n;
              loop invariant res == i * n + j;
              loop invariant 0 <= i <= m;
              loop invariant 0 <= n;
              loop assigns j, res;
            */
            for(int j = 0; j < n; j++) {
                res = res + 1;
            }
        }

        return sign * res;
}

