/*@
logic integer partial_sum(int *a, integer c, integer n) =
  n <= 0 ? 0 : partial_sum(a, c, n - 1) + a[n - 1] * a[c - n];
*/


int foo199(int number) {

		int *arr = (int *)malloc(sizeof(int) * (number + 1));
int arr_len = number + 1;
		arr[0] = 1;
		
            /*@
          loop invariant c >= 1;
          loop invariant arr[0] == 1;
          loop assigns c, arr[0..number];
            */
            for (int c = 1; c <= number; c++) {
			arr[c] = 0;
			
            /*@
          loop invariant 0 <= n <= c;
          loop assigns n, arr[c];
            */
            for (int n = 0; n < c; n++) {
				arr[c] += arr[n]
						* arr[c - n - 1];
			}
            
		}
            
		return arr[number];
}

