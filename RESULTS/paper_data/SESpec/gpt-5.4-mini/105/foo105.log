  logic integer fibo(integer n) =
    n <= 0 ? 0 :
    n == 1 ? 1 :
    fibo(n - 1) + fibo(n - 2);
*/

/*@
  assigns \nothing;
  ensures n < 0 ==> \result == -1;
  ensures n == 0 ==> \result == 0;
  
  ensures n > 0 ==> \result >= 0 [POSTCONDITION FAILED];
