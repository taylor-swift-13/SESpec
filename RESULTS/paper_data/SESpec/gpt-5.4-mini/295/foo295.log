/*@ logic integer fib295(integer n) =
      n <= 0 ? 2 :
      n == 1 ? 1 :
      fib295(n - 1) + fib295(n - 2);
*/

/*@
  requires num >= 1;
  assigns \nothing;
  ensures \result == fib295(num);
*/
int foo295(int num) {
    int *result = (int *)malloc(sizeof(int) * (num + 1));
    int result_len = num + 1;
    result[0] = 2;
    result[1] = 1;

    /*@
      loop invariant 2 <= l <= num + 1;
