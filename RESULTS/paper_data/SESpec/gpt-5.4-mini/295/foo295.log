      loop invariant l >= 3 ==> result[l - 2] == fib295(l - 2);
      loop assigns l, result[0..num];
    */
    for (int l = 2; l <= num; l++) {
        result[l] = result[l - 1] + result[l - 2];
    }

    return result[num];
}

