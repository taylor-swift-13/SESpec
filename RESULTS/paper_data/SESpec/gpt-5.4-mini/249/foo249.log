          loop invariant (\at(start,Pre) <= \at(stop,Pre)) ==> (found >= \at(start,Pre));
          loop invariant (\at(start,Pre) <= \at(stop,Pre)) ==> (num <= \at(stop,Pre));
          loop invariant (\at(start,Pre) <= \at(stop,Pre)) ==> (found <= \at(stop,Pre) + 1);
