/*@
  logic integer count_matching_prefix(int *ar, integer i) =
    i <= 1 ? 0 :
    count_matching_prefix(ar, i - 1) + (ar[i - 2] == i - 1 ? 1 : 0);
*/

/*@
  requires 1 <= ar_len;
  requires 0 <= n <= ar_len;
  requires \valid(&ar[0] + (0..ar_len-1));
