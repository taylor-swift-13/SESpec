int foo391(int n) 
{

        int i = 1;
        int square = 1;
        
        /*@
          loop invariant 1 <= i;
          loop invariant 1 <= square;
          
          loop invariant square >= 1 && i >= 1;
          loop invariant \forall integer k; 1 <= k <= i-1 ==> ( (k*k) == (k * k) );
          
