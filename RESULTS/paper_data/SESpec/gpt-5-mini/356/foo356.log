int foo356(int n);


/*@
ensures \exists integer count_66, temp_65, res_64; (temp_65 <= 0) && (0 <= count_66) && (temp_65 <= n) && (n > 0 ==> 0 <= count_66) && (!(n > 0) ==> temp_65 == n && count_66 == 0 && res_64 == 0 && n == n) ==> (\result == (n ^ res_64));

assigns \nothing;
*/

int foo356(int n) 
{

    int res = 0;
    int count = 0;
    int temp = n;
    
    /* >>> LOOP INVARIANT TO FILL <<< */
    /*@ 
      loop invariant 0 <= count;
      loop invariant temp <= \at(n,Pre);
      loop invariant n == \at(n,Pre);
      loop invariant (\at(n,Pre) > 0) ==> (0 <= count);

      loop invariant (!(\at(n,Pre) > 0)) ==> ((temp == \at(n,Pre)) && (count == 0) && (res == 0) && (n == \at(n,Pre)));

      loop assigns res, temp, count;
    */
    while (temp > 0) {
        if (count % 2 == 0) {
            res = res | (1 << count);
        }
        count++;
        temp >>= 1;
    }
        
    return n ^ res;
}
