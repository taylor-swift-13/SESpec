    \forall integer k; k < lo || k > hi ==> i[k] != k;
*/

/* If the function returns an index it points to a fixed point inside bounds.
     If it returns -1 then no index in the searched interval [0 .. array-1]
     is a fixed point (the function only searches that interval). */
  ensures !(\result == -1) ==> (0 <= \result && \result < i_len && i[\result] == \result);
  ensures \result == -1 ==> (\forall integer idx; 0 <= idx < array ==> i[idx] != idx);
*/
int foo258(int * i, int i_len, int array) {

		int ret = 0;
		int stop = array - 1;
		
            
        /*@
          loop invariant (0 <= \at(array,Pre) - 1) ==> (ret >= 0 && stop <= \at(array,Pre) - 1);
          loop invariant (!(0 <= \at(array,Pre) - 1)) ==> ((stop == \at(array,Pre) - 1)&&(ret == 0)&&(array == \at(array,Pre))&&(i_len == \at(i_len,Pre))&&(i == \at(i,Pre)));
          loop invariant array == \at(array,Pre);
          loop invariant i_len == \at(i_len,Pre);
          loop invariant i == \at(i,Pre);
        */
            while (ret <= stop) {
			int cur = ret + (stop - ret) / 2;
			if (i[cur] == cur) {
				return cur;
			} else if (i[cur] < cur) {
				ret = cur + 1;
			} else {
				stop = cur - 1;
			}
		}
            
		return -1;
}

