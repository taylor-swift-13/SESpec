*/
int foo232(int * pairs, int pairs_len, int array) {

    int count = 0;
    int total = pairs_len;

    /*@
      loop invariant total == \at(pairs_len,Pre);
      loop invariant 0 <= count;
      loop invariant array == \at(array,Pre);
      loop invariant pairs_len == \at(pairs_len,Pre);
