/* The function returns -1 exactly when the total number of non-divisible
     elements in [l..m] is less than b. Conversely, if it returns an index,
     that index lies in [l..m] and the number of non-divisible elements
     in [l..result] is at least b while the number in [l..result-1] is at most b-1. */
  ensures (\result == -1) <==> (count_nd(l, m, code) < b);
