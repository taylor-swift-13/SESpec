  ensures \result == \at(\result,Post); 
*/
int foo342(int code, int b, int l, int m) {

	int result = 0;
	
    /*@
      loop invariant l <= c <= m + 1;
      loop invariant (c <= m && b > 0) ==> result < b;
      loop invariant m == \at(m,Pre);
