#include <stdlib.h>

/*@
  logic integer seq_ret(integer k) =
    k == 0 ? 0
    : k == 1 ? 1
    : seq_ret(k-1) + 2*seq_ret(k-2);
*/

/*@
  requires j >= 1;
  assigns \nothing;
*/
int foo288(int j) {

    int *ret = (int *)malloc(sizeof(int) * (j + 1));
    int ret_len = j + 1;
    ret[0] = 0;
    ret[1] = 1;

    /*@
      loop invariant 2 <= j + 1;
      loop invariant ret_len == j + 1;
