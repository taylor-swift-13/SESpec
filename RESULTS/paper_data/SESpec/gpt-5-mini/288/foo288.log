#include <stdlib.h>

/*@
  logic integer seq_ret(integer k) =
    k == 0 ? 0
    : k == 1 ? 1
    : seq_ret(k-1) + 2*seq_ret(k-2);
*/

/*@
  requires j >= 0;
  assigns \nothing;
  ensures \result >= 0 [POSTCONDITION FAILED];
