#include <stdlib.h>

/*@
  logic integer seq_ret(integer k) =
    k == 0 ? 0
    : k == 1 ? 1
    : seq_ret(k-1) + 2*seq_ret(k-2);
*/

/*@
  requires j >= 1;
  assigns \nothing;
  ensures \result == seq_ret(j) [POSTCONDITION FAILED];
  ensures j == 1 ==> \result == 1;
  ensures j >= 2 ==> (\exists integer k [POSTCONDITION FAILED]; k == j && \result == seq_ret(k));
  ensures \result >= 0 [POSTCONDITION FAILED];
*/
int foo288(int j) {

    int ret_len = j + 1;
    int ret[ret_len];
    ret[0] = 0;
    ret[1] = 1;

    /*@
      loop invariant 2 <= j + 1;
      loop invariant ret_len == j + 1;
      loop invariant ret_len >= 2;
      loop invariant 2 <= p <= j + 1;
      loop invariant ret[0] == seq_ret(0);
      loop invariant ret[1] == seq_ret(1);
      loop assigns p, ret[0..j];
