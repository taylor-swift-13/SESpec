        catalan[i] = 0;

        /*@
          loop invariant 0 <= j <= i;
          loop invariant catalan_len == num + 1;
          loop assigns j, catalan[i];
        */
        for (int j = 0; j < i; j++) {
            catalan[i] += catalan[j] * catalan[i - j - 1];
        }
    }

    return catalan[num];
}

