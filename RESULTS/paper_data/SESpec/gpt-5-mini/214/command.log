int foo214(int num) {

    int *catalan = (int *)malloc(sizeof(int) * (num + 1));
    int catalan_len = num + 1;
    catalan[0] = 1;

    /*@
      loop invariant 1 <= i <= num + 1 || i == 1;
      loop invariant catalan_len == num + 1;
      loop assigns i, catalan[0 .. catalan_len - 1];
    */
