	for (int index = 0; index < num; index++) {

		/*@
		  loop invariant 0 <= index && index <= num;
		  loop invariant \valid(&args[0] + (0 .. args_len-1));
		  loop invariant 0 <= ret;
		  loop invariant (\forall integer i; 0 <= i && i < index ==>
