int foo221(int * arr, int arr_len, int n) {

    int found = 0;
    int offset = arr_len;

    /*@
      loop invariant offset == \at(arr_len,Pre);
      loop invariant found >= 0;
      loop invariant \forall integer k; 0 <= k < arr_len ==> arr[k] == \at(arr[k],Pre);
