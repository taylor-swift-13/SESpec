int foo233(int * arr, int arr_len) {

    int result = arr[0];
    int num = arr[0];

    /*@
      loop invariant 1 <= n <= arr_len;
      loop invariant (n <= arr_len) ==> (result == max_pref(arr, 0, n));
      loop invariant (n <= arr_len) ==> (num == min_pref(arr, 0, n));
