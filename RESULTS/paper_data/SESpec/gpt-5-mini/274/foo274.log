      loop invariant (i < \at(n, Pre)) ==>
        ( (i % 2 == 0 && arr[i] % 2 == 0) ==> (count + arr[i] == sum_even_indices_even_values(arr, 0, i+1)) );

      loop invariant (i < \at(n, Pre)) ==>
        ( (! (i % 2 == 0 && arr[i] % 2 == 0)) ==> (count == sum_even_indices_even_values(arr, 0, i+1)) );

      loop assigns i, count;
    */
    for (int i = 0; i < n; i++) {
        if (i % 2 == 0) {
            if (arr[i] % 2 == 0) {
                count += arr[i];
            }
        }
    }

    return count;
}

