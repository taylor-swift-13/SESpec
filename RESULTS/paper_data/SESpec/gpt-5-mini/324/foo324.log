      loop invariant first >= 0;
      loop invariant (!(first > 0)) ==> (first == 0 && 0 <= result && result <= 9);
      loop assigns result, first;
    */
    while (first > 0) {
        result = first % 10;
        first /= 10;
    }
            
    return result;
}

