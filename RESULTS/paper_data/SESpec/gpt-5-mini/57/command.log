int unknown();

/*@
  requires \true;
  ensures \result == 0 || \result == 1;
*/
int parity_walk(int n) {
    int x = 0;
    int y = 0;

    /*@
      loop invariant (x + y) % 2 == 0;
      loop invariant 0 <= x;
      loop invariant 0 <= y;
