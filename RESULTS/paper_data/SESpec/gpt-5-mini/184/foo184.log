/* No additional top-level predicate or logic function required. */

int foo184(int n) {

    int *sumOfPrimeDivisors = (int *)malloc(sizeof(int) * (n + 1));
    int sumOfPrimeDivisors_len = n + 1;
    sumOfPrimeDivisors[0] = 0;
    sumOfPrimeDivisors[1] = 0;

