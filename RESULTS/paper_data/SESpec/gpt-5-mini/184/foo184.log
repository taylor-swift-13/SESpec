              loop assigns j, sumOfPrimeDivisors[0 .. sumOfPrimeDivisors_len - 1];
            */
            for (int j = i; j <= n; j += i) {
                sumOfPrimeDivisors[j] += i;
            }

        }
    }

    return sumOfPrimeDivisors[n];
}

