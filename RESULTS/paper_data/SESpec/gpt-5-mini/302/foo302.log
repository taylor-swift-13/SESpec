   ensures \result == dp_rec(n) [POSTCONDITION FAILED];
   assigns \nothing;
*/
int foo302(int n) {

    int *dp = (int *)malloc(sizeof(int) * (n + 1));
    int dp_len = n + 1;
    dp[0] = 0;
    dp[1] = 1;

    /*@
      loop invariant 2 <= i;
      loop invariant dp[0] == dp_rec(0) && dp[1] == dp_rec(1);
      loop assigns i, dp[0..n];
    */
    for (int i = 2; i <= n; i++) {
        dp[i] = dp[i - 1] + 2 * dp[i - 2];
    }

    return dp[n];
}

