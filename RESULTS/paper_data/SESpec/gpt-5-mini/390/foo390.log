int foo390(int n, int k) {

        int res = 1;
        int i = 1;
        
            
        /*@
          loop invariant 1 <= \at(k,Pre) ==> 1 <= i <= \at(k,Pre) + 1;
          loop invariant 1 <= \at(k,Pre) ==> res == product_from_to(n - (i - 1) + 1, n);
