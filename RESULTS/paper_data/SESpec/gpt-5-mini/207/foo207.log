          loop invariant \forall integer v; count_eq_int(args, 0, ret, v) == count_eq_int(arr, 0, len, v) + (count_eq_int(args, 0, ret, v) - count_eq_int(arr, 0, len, v));
          loop invariant (ret == args_len || len == arr_len) ==> (ret <= args_len && len <= arr_len);
