*/
int foo312(int count) {

	int ret = 0;
	int diameter = 2 * count;
	int center = diameter * diameter;
	
	/*@
	  loop invariant 0 <= ret;
	  loop invariant diameter == 2 * \at(count,Pre);
	  loop invariant center == diameter * diameter;
	  loop invariant count == \at(count,Pre);
