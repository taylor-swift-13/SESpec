		int *N = (int *)malloc(sizeof(int) * (c + 1));
int N_len = c + 1;
		N[0] = 2;
		N[1] = 1;
		
            
        /*@
          loop invariant 2 <= p <= c + 1;
          loop invariant \forall integer i; 0 <= i < p ==> N[i] == seq(i);
          loop invariant p >= 2 ==> 0 <= p-2;
          loop invariant p >= 2 ==> p-1 < N_len;
        */
            for (int p = 2; p <= c; p++) {
			N[p] = N[p - 1]
					+ 2 * N[p - 2];
		}
            
		return N[c];
}

