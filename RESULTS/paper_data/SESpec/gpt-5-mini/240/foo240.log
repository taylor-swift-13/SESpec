      m <= 0 ? 1 : 2 * pow2(m-1);
*/
/*@
  requires n >= 0;
  assigns \nothing;
  ensures n == 0 ==> \result == 1 [POSTCONDITION FAILED];
  ensures n >= 1 ==> \result >= 1 [POSTCONDITION FAILED];
  ensures \result >= 0 [POSTCONDITION FAILED];
*/
int foo240(int n) {

    int sum = 0;
    int *dp = (int *)malloc(sizeof(int) * (n + 1));
    int dp_len = n + 1;
    dp[0] = 1;

    /*@
      loop invariant 0 <= i <= n+1;
      loop assigns i, dp[0 .. n];
    */
    for (int i = 1; i <= n; i++) {

        /*@
          loop invariant 0 <= j <= i;
          loop invariant 0 <= i && i <= n+1;
          loop assigns j, dp[0 .. n];
        */
        for (int j = 0; j < i; j++) {
            dp[i] = dp[i] + dp[j];
        }

    }

    return dp[n];
}

